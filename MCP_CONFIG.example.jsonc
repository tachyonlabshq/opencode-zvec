{
  "mcp": {
    "zvec-memory": {
      "type": "local",
      "command": [
        "python3",
        "./zvec-memory/mcp/server.py"
      ],
      "enabled": true,
      "environment": {
        "ZVEC_MAX_STORAGE_MB": "5120",
        "ZVEC_AUTO_PRUNE": "1",
        "ZVEC_MAX_ITEMS": "250000"
      }
    }
  }
}
